AGENT_TIMEZONE=Asia/Shanghai
AGENT_INBOUND_DEBOUNCE_MS=1000
AGENT_DEFAULT_TARGET_PLUGIN=auto
API_HOST=127.0.0.1
API_PORT=3030

LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_MS=60000
LLM_STREAM_ENABLED=true
LLM_EXTRA_PARAMS={}
# LLM_FOLLOWUP_EXTRA_PARAMS={}

FEISHU_ENABLED=false
FEISHU_CONNECTION_MODE=websocket
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REQUIRE_MENTION=true
FEISHU_PAIRING_COMMAND=/pair alice

WECHAT_ENABLED=false
WECHAT_ILINK_BOT_TOKEN=
WECHAT_ILINK_BASE_URL=https://ilinkai.weixin.qq.com
WECHAT_ILINK_POLL_TIMEOUT_MS=35000

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# SELFIE_IMAGE_API_KEY=
# SELFIE_IMAGE_API_BASE_URL=https://api.openai.com/v1
SELFIE_IMAGE_API_MODEL=gpt-image-2
SELFIE_IMAGE_API_SIZE=768x1024
SELFIE_IMAGE_API_QUALITY=low
SELFIE_IMAGE_API_OUTPUT_FORMAT=jpeg
SELFIE_IMAGE_API_OUTPUT_COMPRESSION=45
SELFIE_IMAGE_API_TIMEOUT_MS=120000
SELFIE_REFERENCE_DIR=assets/selfie/references
SELFIE_OUTPUT_DIR=assets/generated/selfies
SELFIE_CODEX_COMMAND=codex
SELFIE_CODEX_TIMEOUT_MS=180000
SELFIE_MAX_BYTES=10485760

GENIE_TTS_BASE_URL=http://127.0.0.1:8000
GENIE_TTS_CHARACTER_NAME=alice
GENIE_TTS_MODEL_DIR=assets/tts/models/alice
GENIE_TTS_LANGUAGE=zh
GENIE_TTS_REFERENCE_AUDIO=assets/tts/reference/reference.wav
GENIE_TTS_REFERENCE_TEXT=assets/tts/reference/reference.txt
GENIE_TTS_OUTPUT_DIR=assets/generated/tts
GENIE_TTS_TIMEOUT_MS=120000

{
  "name": "alice-companion-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "dev:api": "npm run build && node dist/apps/api/src/index.js",
    "tts:moss:conda": ".miniconda/_conda create -y -p .conda-moss python=3.11 pip",
    "tts:moss:install": "npm run tts:moss:conda && .conda-moss/bin/python -m pip install -r scripts/moss_tts_onnx/requirements.txt",
    "tts:moss:start": ".conda-moss/bin/python scripts/moss_tts_onnx/service.py",
    "test:selfie-api": "node scripts/test-selfie-image-api.mjs",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "test": "npm run build && node --test \"dist/tests/**/*.test.js\""
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "ffmpeg-static": "^5.3.0",
    "qrcode": "^1.5.4",
    "silk-wasm": "^3.3.2"
  }
}
